import math

def calculate_sum(numbers):
    total = 0

    for num in numbers:
        total += num

    return total


def mean(numbers):
    return calculate_sum(numbers) / len(numbers)


def variance(numbers):

    avg = mean(numbers)

    total = 0

    for num in numbers:
        total += (num - avg) ** 2

    return total / len(numbers)


def standard_deviation(numbers):
    return math.sqrt(variance(numbers))


def mean_deviation(numbers):

    avg = mean(numbers)

    total = 0

    for num in numbers:
        total += abs(num - avg)

    return total / len(numbers)


def main():

    numbers = [10, 15, 15, 25, 35]

    print("Numbers:", numbers)

    print("Sum:", calculate_sum(numbers))

    print("Mean:", mean(numbers))

    print("Variance:", variance(numbers))

    print("Standard Deviation:",
          standard_deviation(numbers))

    print("Mean Deviation:",
          mean_deviation(numbers))

main()
